  ];

  const dayNames = ['တနင်္လာ', 'အင်္ဂါ', 'ဗုဒ္ဓဟူး', 'ကြာသပတေး', 'သောကြာ'];
  const MAX_COLS = 58;
  const TOTAL_ROWS = 25; // ပိတ်ရက် + အနာဂတ် ပါ
  let currentView = 'morning';

  // ကော်လံ ခေါင်းစဉ် ၁-၅၈
  const headerRow = document.getElementById('headerRow');
  for(let i=1; i<=MAX_COLS; i++) {
    headerRow.innerHTML += `<th>${i}</th>`;
  }

  function switchView(view, btn) {
    currentView = view;
    document.querySelectorAll('.toggle-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    buildTable();
  }

  function buildTable() {
    const tbody = document.getElementById('tableBody');
    tbody.innerHTML = '';
    
    // Row 0-25 အထိ ဖြည့်ခြင်း
    for(let row=0; row<TOTAL_ROWS; row++) {
      const tr = document.createElement('tr');
      
      // ပထမကော်လံ (DAY Label)
      const dayTd = document.createElement('td');
      dayTd.className = 'day-col';
      
      // ✅ Row 0 = "1" (နေ့အမည်မပါ)
      // ✅ Row 1-20 = "2 တနင်္လာ", "3 အင်္ဂါ"...
      // ✅ Row 21-25 = ပိတ်ရက်/အနာဂတ် (နေ့အမည်မပါ)
      if(row === 0) {
        dayTd.innerHTML = `${row+1}`;
      } else if(row <= 20) {
        const dayName = dayNames[(row-1) % 5];
        dayTd.innerHTML = `${row+1}<br><small style="font-size:9px">${dayName}</small>`;
      } else {
        dayTd.innerHTML = `${row+1}`;
      }
      
      // ✅ အရောင် အလှည့်ကျ
      if(row % 2 === 0 && row > 0) {
        dayTd.classList.add('odd-row');
      }
      
      tr.appendChild(dayTd);
      
      // ဂဏန်းများ သို့မဟုတ် ● သို့မဟုတ် အလွတ်
      const data = (currentView === 'morning') ? morningData[row] : eveningData[row];
      
      for(let col=0; col<MAX_COLS; col++) {
        const td = document.createElement('td');
        
        if(row >= 22) {
          // ✅ အနာဂတ် (Row 22-25) = အလွတ်
          td.className = 'empty-future-cell';
          td.textContent = '';
        } else if(data === null) {
          // ✅ ပိတ်ရက် = ●
          td.className = 'holiday-cell';
          td.textContent = '●';
        } else if(data[col] !== undefined && data[col] !== 0) {
          // ✅ ဂဏန်းရှိရင် ပြမယ်
          td.className = currentView === 'morning' ? 'num-cell-morning' : 'num-cell-evening';
          td.textContent = String(data[col]).padStart(2,'0');
        } else {
          // ✅ ဂဏန်းမရှိရင် အလွတ်
          td.className = 'empty-future-cell';
          td.textContent = '';
        }
        
        tr.appendChild(td);
      }
      
      tbody.appendChild(tr);
    }
  }

  // Page load ဖြစ်တာနဲ့ Table ကို ဆောက်မယ်
  buildTable();
</script>

</body>
</html>
