    null, // Row 22 - အနာဂတ် (အလွတ်)
    null, // Row 23 - အနာဂတ် (အလွတ်)
    null, // Row 24 - အနာဂတ် (အလွတ်)
    null  // Row 25 - အနာဂတ် (အလွတ်)
  ];

  // နေပိုင်း ဂဏန်းများ (ပုံစံတူ)
  const eveningData = [
    null, // Row 0 - ပိတ်ရက်
    [34,12,13,57,48,73,70,00,52,78,71,42,46,65,73,19,48,44,19,49,21,61,15,68,42,53,65,63,15,65,66,53,63,35,46,58,16,40,12,19,55,63,73,22,59,72,47,40,54,56,52,56,12,58,16,67,76,78],
    [33,25,24,56,92,86,13,72,75,65,57,15,05,42,93,08,38,04,52,02,82,41,01,32,62,34,15,18,96,36,05,77,61,75,99,36,56,40,51,14,84,47,09,80,77,51,08,95,03,97,00,00,00,00,00,00,00,00],
    [85,25,20,29,90,82,55,85,55,50,89,26,59,17,31,41,63,13,94,76,51,21,24,50,30,06,22,95,92,15,73,25,99,48,68,74,17,88,38,37,52,26,98,23,03,19,17,48,37,00,00,00,00,00,00,00,00],
    [30,12,12,71,35,00,31,97,68,89,48,20,38,23,15,82,17,48,55,73,39,95,61,72,49,73,46,97,60,49,85,21,26,52,45,35,05,66,79,34,14,78,33,95,19,78,73,42,20,53,37,74,00,00,00,00,00,00],
    [50,66,36,22,07,00,97,34,64,65,83,78,23,47,26,52,26,36,00,77,90,61,89,26,42,49,88,13,46,07,97,03,95,65,64,02,26,53,00,63,37,85,20,26,82,14,28,64,58,08,73,00,00,00,00,00,00,00],
    null, // Row 6 - ပိတ်ရက်
    null, // Row 7 - ပိတ်ရက်
    [01,10,17,20,79,05,86,00,28,18,00,75,00,76,28,13,86,76,11,37,00,53,38,71,80,71,78,34,38,30,73,35,52,92,11,00,39,30,86,33,19,80,68,92,57,15,27,20,33,00,00,00,00,00,00,00,00],
    [08,81,90,12,76,88,77,90,68,82,12,10,93,18,06,00,04,64,21,33,00,83,38,71,80,55,14,02,00,33,30,74,86,28,46,21,24,25,15,55,60,95,83,70,79,53,10,40,00,00,00,00,00,00,00,00,00,00],
    [12,84,10,51,50,00,39,95,39,34,82,53,77,20,00,04,71,79,15,67,42,48,47,46,02,68,97,53,20,60,88,34,48,25,20,96,78,73,59,14,18,39,97,90,19,62,47,49,08,38,92,28,90,00,00,00,00,00,00],
